{
  "name": "sudokusolver-api",
  "version": "3.0.0",
  "description": "Sudoku Solver REST API with puzzle generation",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --ext ts,tsx --exec \"tsx index.ts\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write . --ignore-path .gitignore",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exphoenee/SudokuSolver-API.git"
  },
  "keywords": [
    "Sudoku",
    "Solver",
    "API",
    "Express"
  ],
  "author": "exphoenee",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/exphoenee/SudokuSolver-API/issues"
  },
  "homepage": "https://github.com/exphoenee/SudokuSolver-API#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-ts": "^1.1.22",
    "nodemon": "^2.0.20",
    "prettier": "^3.2.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "tsx": true,
              "dynamicImport": true
            },
            "target": "esnext"
          },
          "module": {
            "type": "esnext"
          }
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "verbose": true
  }
}
