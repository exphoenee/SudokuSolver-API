{
  "name": "sudokusolver-api",
  "version": "3.0.0",
  "description": "Sudoku Solver REST API with puzzle generation",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write . --ignore-path .gitignore"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exphoenee/SudokuSolver-API.git"
  },
  "keywords": [
    "Sudoku",
    "Solver",
    "API",
    "Express"
  ],
  "author": "exphoenee",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/exphoenee/SudokuSolver-API/issues"
  },
  "homepage": "https://github.com/exphoenee/SudokuSolver-API#readme",
  "dependencies": {
    "express": "^4.18.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.20",
    "prettier": "^3.2.5"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": [
      "js",
      "mjs"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "verbose": true
  }
}
